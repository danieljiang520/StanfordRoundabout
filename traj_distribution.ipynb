      "outputs": [],
      "source": [
        "# Analyze MCMC results\n",
        "mcmc_failures = mcmc_result[\"failures\"]\n",
        "mcmc_samples = mcmc_result[\"samples\"]\n",
        "\n",
        "print(f\"MCMC Results Summary:\")\n",
        "print(f\"  Acceptance rate: {mcmc_result['acceptance_rate']:.2%}\")\n",
        "print(f\"  Total failures discovered: {len(mcmc_failures)}\")\n",
        "print(f\"  Post burn-in samples: {len(mcmc_samples)}\")\n",
        "\n",
        "# Sort failures by log probability (most likely first)\n",
        "mcmc_failures_sorted = sorted(mcmc_failures, key=lambda x: x[\"nominal_log_prob\"], reverse=True)\n",
        "\n",
        "print(f\"\\nTop 5 most likely failures from MCMC:\")\n",
        "for i, f in enumerate(mcmc_failures_sorted[:5]):\n",
        "    print(f\"  {i+1}. log_prob={f['nominal_log_prob']:.1f}, \"\n",
        "          f\"min_dist={f['metrics']['min_distance']:.2f}, \"\n",
        "          f\"jerk={f['metrics']['jerk_score']:.2f}\")"
      ]
