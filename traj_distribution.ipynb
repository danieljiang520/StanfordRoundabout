      ],
      "source": [
        "# Run MCMC to sample from failure distribution\n",
        "# Use best params from falsification as starting point (if available)\n",
        "if fuzzer.best_result is not None:\n",
        "    initial_params = fuzzer.best_result[\"params\"]\n",
        "    print(\"Starting MCMC from falsification best params\")\n",
        "else:\n",
        "    initial_params = None\n",
        "    print(\"Starting MCMC from nominal params\")\n",
        "\n",
        "mcmc_result = fuzzer.mcmc_sample(\n",
        "    n_iterations=500,      # Total iterations (reduce for faster testing)\n",
        "    burn_in=100,           # Discard first 100 samples\n",
        "    n_rollouts_per_step=3, # Rollouts per iteration\n",
        "    proposal_std=0.1,      # Proposal step size (relative to bounds)\n",
        "    failure_weight=10.0,   # How much to overweight failures\n",
        "    initial_params=initial_params,\n",
        "    verbose=True,\n",
        ")"
      ]
    },
