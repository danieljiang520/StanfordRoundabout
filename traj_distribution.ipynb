      "source": [
        "# Compare MCMC failures with falsification failures\n",
        "fig, axes = plt.subplots(2, 3, figsize=(14, 8))\n",
        "axes = axes.flatten()\n",
        "\n",
        "metric_names = [\"min_distance\", \"avg_speed_ratio\", \"jerk_score\", \"brake_severity\", \"lane_changes\", \"on_road_frac\"]\n",
        "metric_labels = [\"Min Distance (m)\", \"Avg Speed Ratio\", \"Jerk Score\", \"Brake Severity\", \"Lane Changes\", \"On-Road Fraction\"]\n",
        "\n",
        "# Get falsification failures (from history)\n",
        "falsification_failures = [f for rec in fuzzer._history for f in rec.get(\"failures\", [])]\n",
        "\n",
        "for idx, (metric, label) in enumerate(zip(metric_names, metric_labels)):\n",
        "    ax = axes[idx]\n",
        "    \n",
        "    # MCMC failures\n",
        "    mcmc_vals = [f[\"metrics\"][metric] for f in mcmc_failures]\n",
        "    # Falsification failures\n",
        "    fals_vals = [f[\"metrics\"][metric] for f in falsification_failures] if falsification_failures else []\n",
        "    \n",
        "    # Plot histograms\n",
        "    if mcmc_vals:\n",
        "        ax.hist(mcmc_vals, bins=15, alpha=0.6, label=f\"MCMC (n={len(mcmc_vals)})\", color=\"blue\", edgecolor=\"black\")\n",
        "    if fals_vals:\n",
        "        ax.hist(fals_vals, bins=15, alpha=0.6, label=f\"Falsification (n={len(fals_vals)})\", color=\"red\", edgecolor=\"black\")\n",
        "    \n",
        "    ax.set_xlabel(label)\n",
        "    ax.set_ylabel(\"Count\")\n",
        "    ax.set_title(f\"Failure Distribution: {label}\")\n",
        "    ax.legend()\n",
        "    ax.grid(True, alpha=0.3)\n",
        "\n",
        "plt.suptitle(\"Comparison of Failure Distributions: MCMC vs Falsification\", fontsize=14, y=1.02)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Compare log probabilities\n",
        "print(\"\\nLog probability comparison:\")\n",
        "mcmc_lps = [f[\"nominal_log_prob\"] for f in mcmc_failures]\n",
        "fals_lps = [f[\"nominal_log_prob\"] for f in falsification_failures] if falsification_failures else []\n",
        "\n",
        "if mcmc_lps:\n",
        "    print(f\"  MCMC failures: mean={np.mean(mcmc_lps):.1f}, max={np.max(mcmc_lps):.1f}, min={np.min(mcmc_lps):.1f}\")\n",
        "if fals_lps:\n",
        "    print(f\"  Falsification failures: mean={np.mean(fals_lps):.1f}, max={np.max(fals_lps):.1f}, min={np.min(fals_lps):.1f}\")"
      ]
    },
